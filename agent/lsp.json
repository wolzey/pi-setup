{
  "version": 1,
  "servers": [
    {
      "id": "gopls",
      "enabled": true,
      "include": ["**/*.go"],
      "exclude": ["**/vendor/**"],
      "rootMarkers": ["go.mod", "go.work", ".git"],
      "bin": "/Users/ethanwolz/go/bin/gopls",
      "args": [],
      "cwd": "{root}",
      "languageIdByExtension": {
        ".go": "go"
      },
      "startupTimeoutMs": 45000,
      "diagnosticsWaitMs": 1500,
      "initializationOptions": {},
      "settings": {}
    },
    {
      "id": "ruby-lsp",
      "enabled": true,
      "include": [
        "**/*.rb",
        "**/*.rake",
        "**/*.gemspec",
        "**/*.ru",
        "**/*.erb"
      ],
      "exclude": ["**/vendor/**", "**/tmp/**", "**/log/**"],
      "rootMarkers": ["Gemfile", ".ruby-version", ".ruby-gemset", "gems.rb", ".git"],
      "bin": "/opt/homebrew/lib/ruby/gems/4.0.0/bin/ruby-lsp",
      "args": [],
      "cwd": "{root}",
      "languageIdByExtension": {
        ".rb": "ruby",
        ".rake": "ruby",
        ".gemspec": "ruby",
        ".ru": "ruby",
        ".erb": "erb"
      },
      "startupTimeoutMs": 45000,
      "diagnosticsWaitMs": 2000,
      "initializationOptions": {
        "enabledFeatures": {
          "codeActions": true,
          "codeLens": true,
          "completion": true,
          "definition": true,
          "diagnostics": true,
          "documentHighlights": true,
          "documentLink": true,
          "documentSymbols": true,
          "foldingRanges": true,
          "formatting": true,
          "hover": true,
          "inlayHint": true,
          "onTypeFormatting": true,
          "selectionRanges": true,
          "semanticHighlighting": true,
          "signatureHelp": true,
          "typeHierarchy": true,
          "workspaceSymbol": true
        }
      },
      "settings": {}
    },
    {
      "id": "typescript-language-server",
      "enabled": true,
      "include": [
        "**/*.ts",
        "**/*.tsx",
        "**/*.js",
        "**/*.jsx",
        "**/*.mts",
        "**/*.cts",
        "**/*.mjs",
        "**/*.cjs",
        "**/*.vue"
      ],
      "exclude": ["**/node_modules/**", "**/dist/**", "**/build/**", "**/.next/**", "**/.nuxt/**"],
      "rootMarkers": ["tsconfig.json", "jsconfig.json", "package.json", ".git"],
      "bin": "/Users/ethanwolz/.nvm/versions/node/v22.18.0/bin/typescript-language-server",
      "args": ["--stdio"],
      "cwd": "{root}",
      "languageIdByExtension": {
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact",
        ".mts": "typescript",
        ".cts": "typescript",
        ".mjs": "javascript",
        ".cjs": "javascript",
        ".vue": "vue"
      },
      "startupTimeoutMs": 45000,
      "diagnosticsWaitMs": 2000,
      "initializationOptions": {},
      "settings": {}
    }
  ]
}
